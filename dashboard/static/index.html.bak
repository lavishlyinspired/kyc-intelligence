//  Circular Ownership
// ═══════════════════════════════════════════════════════════════════════════════
async function loadRings(){
  const el = document.getElementById('rings-list');loading(el);
  const d = await api('/api/rings');
  if(!d.length){el.innerHTML='<div style="color:var(--text2)">No circular ownership detected.</div>';return}
  el.innerHTML = d.map(r=>`
    <div class="card">
      <div class="flex flex-between flex-center">
        <strong>Ring #${r.scc}</strong>
        <span style="color:var(--red);font-weight:600">${r.size} entities</span>
      </div>
      <div style="margin-top:8px">
        ${r.members.map(m=>`<a href="#" onclick="showEntity('${m.id}');return false">${m.name}</a> (${m.jurisdiction})`).join(' ↔ ')}
      </div>
    </div>
  `).join('');
}

