<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>KYC Intelligence</title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🔎</text></svg>">
<style>
:root{--bg:#0f1117;--bg2:#161b22;--bg3:#1c2333;--border:#30363d;--text:#e6edf3;--text2:#8b949e;--accent:#58a6ff;--accent2:#3fb950;--red:#f85149;--orange:#d29922;--yellow:#e3b341;--purple:#bc8cff;--radius:8px;--shadow:0 1px 3px rgba(0,0,0,.4)}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;background:var(--bg);color:var(--text);display:flex;min-height:100vh}
a{color:var(--accent);text-decoration:none}
a:hover{text-decoration:underline}

/* Sidebar */
.sidebar{width:240px;background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;position:fixed;top:0;left:0;bottom:0;z-index:100}
.sidebar-logo{padding:20px;font-size:18px;font-weight:700;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px}
.sidebar-nav{flex:1;padding:8px}
.nav-item{display:flex;align-items:center;gap:10px;padding:10px 16px;border-radius:var(--radius);color:var(--text2);cursor:pointer;font-size:14px;transition:.15s}
.nav-item:hover{background:var(--bg3);color:var(--text)}
.nav-item.active{background:rgba(88,166,255,.15);color:var(--accent)}
.nav-item .icon{font-size:18px;width:24px;text-align:center}
.nav-section{padding:8px 16px 4px;font-size:11px;text-transform:uppercase;color:var(--text2);letter-spacing:.5px;margin-top:12px}

/* Main content */
.main{margin-left:240px;flex:1;min-width:0}
.topbar{padding:16px 24px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:var(--bg2)}
.topbar h1{font-size:20px;font-weight:600}
.topbar-badges{display:flex;gap:8px}
.badge{padding:4px 10px;border-radius:12px;font-size:12px;font-weight:500}
.badge-green{background:rgba(63,185,80,.15);color:var(--accent2)}
.badge-red{background:rgba(248,81,73,.15);color:var(--red)}
.content{padding:24px}

/* Cards */
.card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:20px;margin-bottom:16px}
.card h3{font-size:16px;margin-bottom:12px;color:var(--text)}
.card-grid{display:grid;gap:16px}
.card-grid-5{grid-template-columns:repeat(5,1fr)}
.card-grid-4{grid-template-columns:repeat(4,1fr)}
.card-grid-3{grid-template-columns:repeat(3,1fr)}
.card-grid-2{grid-template-columns:repeat(2,1fr)}

/* KPI */
.kpi{text-align:center;padding:16px}
.kpi-value{font-size:28px;font-weight:700;margin-bottom:4px}
.kpi-label{font-size:12px;color:var(--text2);text-transform:uppercase;letter-spacing:.5px}

/* Tables */
.table-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:13px}
th{text-align:left;padding:8px 12px;background:var(--bg3);color:var(--text2);font-weight:600;font-size:11px;text-transform:uppercase;letter-spacing:.3px;border-bottom:1px solid var(--border);position:sticky;top:0}
td{padding:8px 12px;border-bottom:1px solid var(--border)}
tr:hover td{background:rgba(88,166,255,.05)}
.risk-critical{color:var(--red);font-weight:700}
.risk-high{color:var(--orange);font-weight:600}
.risk-medium{color:var(--yellow)}
.risk-low{color:var(--accent2)}
.risk-clean{color:var(--text2)}

/* Badges */
.tag{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600}
.tag-sanctioned{background:rgba(248,81,73,.2);color:var(--red)}
.tag-pep{background:rgba(188,140,255,.2);color:var(--purple)}
.tag-high{background:rgba(248,81,73,.15);color:var(--red)}
.tag-medium{background:rgba(210,153,34,.15);color:var(--orange)}
.tag-low{background:rgba(63,185,80,.15);color:var(--accent2)}

/* Form controls */
input,select,textarea{background:var(--bg3);border:1px solid var(--border);color:var(--text);padding:8px 12px;border-radius:var(--radius);font-size:13px;outline:none;transition:.15s}
input:focus,select:focus,textarea:focus{border-color:var(--accent)}
textarea{font-family:'SF Mono',SFMono-Regular,Consolas,'Liberation Mono',Menlo,monospace;font-size:12px;resize:vertical}
button{background:var(--accent);color:#fff;border:none;padding:8px 16px;border-radius:var(--radius);font-size:13px;cursor:pointer;font-weight:500;transition:.15s}
button:hover{filter:brightness(1.1)}
button.secondary{background:var(--bg3);color:var(--text);border:1px solid var(--border)}
button.secondary:hover{background:var(--border)}
.btn-group{display:flex;gap:8px}

/* Tabs */
.tabs{display:flex;gap:0;border-bottom:1px solid var(--border);margin-bottom:16px}
.tab{padding:8px 16px;cursor:pointer;color:var(--text2);font-size:13px;border-bottom:2px solid transparent;transition:.15s}
.tab:hover{color:var(--text)}
.tab.active{color:var(--accent);border-bottom-color:var(--accent)}

/* Chart containers */
.chart-bar{display:flex;align-items:end;gap:4px;height:120px;padding-top:8px}
.chart-bar-item{flex:1;border-radius:4px 4px 0 0;min-width:20px;position:relative;transition:.3s}
.chart-bar-item:hover{filter:brightness(1.2)}
.chart-bar-label{font-size:10px;color:var(--text2);text-align:center;margin-top:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.chart-bar-value{font-size:10px;color:var(--text);text-align:center;position:absolute;top:-16px;width:100%}

/* Graph canvas */
#graph-canvas{width:100%;height:500px;background:var(--bg);border:1px solid var(--border);border-radius:var(--radius)}

/* Query editor */
.query-editor{display:flex;flex-direction:column;gap:12px}
.query-results{max-height:400px;overflow:auto;font-family:'SF Mono',SFMono-Regular,Consolas,'Liberation Mono',Menlo,monospace;font-size:12px;background:var(--bg);padding:12px;border-radius:var(--radius);border:1px solid var(--border)}
.query-results pre{white-space:pre-wrap;word-break:break-all}

/* Loading */
.spinner{display:inline-block;width:16px;height:16px;border:2px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin .6s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-overlay{display:flex;align-items:center;justify-content:center;padding:40px;color:var(--text2)}

/* Page visibility */
.page{display:none}
.page.active{display:block}

/* Responsive */
@media(max-width:1200px){.card-grid-5{grid-template-columns:repeat(3,1fr)}}
@media(max-width:900px){.card-grid-5,.card-grid-4{grid-template-columns:repeat(2,1fr)}.sidebar{width:60px}.sidebar .nav-label,.sidebar .nav-section,.sidebar-logo span{display:none}.main{margin-left:60px}}

/* Entity detail panel */
.detail-panel{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.detail-field{margin-bottom:8px}
.detail-field label{font-size:11px;color:var(--text2);text-transform:uppercase;display:block;margin-bottom:2px}
.detail-field .val{font-size:14px}

/* Scrollable table container */
.scrollable-table{max-height:500px;overflow-y:auto}

/* Flex utilities */
.flex{display:flex}.flex-between{justify-content:space-between}.flex-center{align-items:center}.gap-8{gap:8px}.gap-16{gap:16px}.mb-16{margin-bottom:16px}.mt-8{margin-top:8px}
</style>
</head>
<body>

<!-- ═══ Sidebar ═══ -->
<nav class="sidebar">
  <div class="sidebar-logo">🔎 <span>KYC Intel</span></div>
  <div class="sidebar-nav">
    <div class="nav-section">Overview</div>
    <div class="nav-item active" data-page="dashboard"><span class="icon">📊</span><span class="nav-label">Dashboard</span></div>

    <div class="nav-section">Investigation</div>
    <div class="nav-item" data-page="entities"><span class="icon">🏢</span><span class="nav-label">Entities</span></div>
    <div class="nav-item" data-page="persons"><span class="icon">👤</span><span class="nav-label">Persons</span></div>
    <div class="nav-item" data-page="ubo"><span class="icon">🔗</span><span class="nav-label">UBO Chains</span></div>
    <div class="nav-item" data-page="graph"><span class="icon">🕸️</span><span class="nav-label">Graph Explorer</span></div>

    <div class="nav-section">Analysis</div>
    <div class="nav-item" data-page="risk"><span class="icon">⚠️</span><span class="nav-label">Risk Analysis</span></div>
    <div class="nav-item" data-page="rings"><span class="icon">🔄</span><span class="nav-label">Circular Ownership</span></div>
    <div class="nav-item" data-page="transactions"><span class="icon">💰</span><span class="nav-label">Transactions</span></div>
    <div class="nav-item" data-page="shells"><span class="icon">🐚</span><span class="nav-label">Shell Companies</span></div>

    <div class="nav-section">Tools</div>
    <div class="nav-item" data-page="cypher"><span class="icon">⚡</span><span class="nav-label">Cypher Console</span></div>
    <div class="nav-item" data-page="sparql"><span class="icon">🔍</span><span class="nav-label">SPARQL Console</span></div>
    <div class="nav-item" data-page="ontology"><span class="icon">📚</span><span class="nav-label">Ontology Browser</span></div>
  </div>
</nav>

<!-- ═══ Main ═══ -->
<div class="main">
<div class="topbar">
  <h1 id="page-title">Dashboard</h1>
  <div class="topbar-badges">
    <span class="badge badge-green" id="neo4j-status">Neo4j ●</span>
    <span class="badge badge-green" id="graphdb-status">GraphDB ●</span>
  </div>
</div>
<div class="content">

<!-- ═══════════════════════════════════════════════════════════════════════════
     PAGE: Dashboard
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="page active" id="page-dashboard">
  <div class="card-grid card-grid-5 mb-16" id="kpi-row"></div>

  <div class="card-grid card-grid-2">
    <div class="card">
      <h3>Risk Distribution</h3>
      <div id="risk-chart" class="chart-bar"></div>
    </div>
    <div class="card">
      <h3>Risk by Jurisdiction</h3>
      <div id="jur-chart" class="chart-bar"></div>
    </div>
  </div>

  <div class="card">
    <h3>Top Risk Entities</h3>
    <div class="scrollable-table" id="dash-top-risk"></div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════
     PAGE: Entities
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="page" id="page-entities">
  <div class="card">
    <div class="flex flex-between flex-center mb-16">
      <div class="flex gap-8">
        <input type="text" id="entity-search" placeholder="Search entities..." style="width:200px">
        <select id="entity-jur-filter"><option value="">All jurisdictions</option></select>
        <select id="entity-tier-filter">
          <option value="">All risk tiers</option>
          <option value="high">High</option>
          <option value="medium">Medium</option>
          <option value="low">Low</option>
        </select>
      </div>
      <div class="flex gap-8">
        <button class="secondary" id="entity-prev">← Prev</button>
        <span id="entity-page-info" style="padding:8px;font-size:13px;color:var(--text2)"></span>
        <button class="secondary" id="entity-next">Next →</button>
      </div>
    </div>
    <div class="scrollable-table" id="entity-table"></div>
  </div>
  <div class="card" id="entity-detail-card" style="display:none">
    <h3 id="entity-detail-title">Entity Details</h3>
    <div id="entity-detail-body"></div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════
     PAGE: Persons
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="page" id="page-persons">
  <div class="card">
    <div class="flex gap-8 mb-16">
      <button class="secondary" onclick="loadPersons()">All</button>
      <button class="secondary" onclick="loadPersons('sanctioned')">Sanctioned</button>
      <button class="secondary" onclick="loadPersons('pep')">PEPs</button>
    </div>
    <div class="scrollable-table" id="persons-table"></div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════
     PAGE: UBO Chains
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="page" id="page-ubo">
  <div class="card">
    <div class="flex gap-8 mb-16">
      <input type="text" id="ubo-entity-id" placeholder="Entity ID (e.g. ENTITY_0042)" style="width:260px">
      <select id="ubo-depth">
        <option value="3">Max 3 hops</option>
        <option value="6" selected>Max 6 hops</option>
        <option value="10">Max 10 hops</option>
      </select>
      <button onclick="findUBO()">Find UBO Chain</button>
    </div>
    <div id="ubo-results"></div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════
     PAGE: Graph Explorer
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="page" id="page-graph">
  <div class="card">
    <div class="flex gap-8 mb-16">
      <input type="text" id="graph-entity-id" placeholder="Entity ID (e.g. ENTITY_0042)" style="width:260px">
      <select id="graph-depth">
        <option value="1">Depth 1</option>
        <option value="2" selected>Depth 2</option>
        <option value="3">Depth 3</option>
      </select>
      <button onclick="loadGraph()">Visualize</button>
    </div>
    <canvas id="graph-canvas"></canvas>
    <div id="graph-legend" class="mt-8" style="font-size:12px;color:var(--text2)">
      <span style="color:#f85149">● Sanctioned</span> &nbsp;
      <span style="color:#bc8cff">● PEP</span> &nbsp;
      <span style="color:#f0883e">● High-Risk Entity</span> &nbsp;
      <span style="color:#58a6ff">● Entity</span> &nbsp;
      <span style="color:#8b949e">● Person</span>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════
     PAGE: Risk Analysis
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="page" id="page-risk">
  <div class="card-grid card-grid-2 mb-16">
    <div class="card">
      <h3>Risk Score Distribution</h3>
      <div id="risk-dist-chart" class="chart-bar"></div>
    </div>
    <div class="card">
      <h3>Jurisdiction Risk Heat Map</h3>
      <div class="scrollable-table" id="jur-heatmap"></div>
    </div>
  </div>
  <div class="card">
    <h3>Risk Score Formula</h3>
    <div style="font-size:13px;color:var(--text2);line-height:1.8">
      <code>kycRiskScore = jurisdictionRisk + sanctionedUBO + pepControl + circularOwnership</code><br>
      <strong>jurisdictionRisk:</strong> high=35, medium=15, low=0<br>
      <strong>sanctionedUBO:</strong> +40 if any sanctioned person in ownership chain (up to 6 hops)<br>
      <strong>pepControl:</strong> +15 if directly controlled by a PEP<br>
      <strong>circularOwnership:</strong> +20 if entity is in an SCC ring
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════
     PAGE: Circular Ownership
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="page" id="page-rings">
  <div class="card">
    <h3>Detected Circular Ownership Rings (SCC)</h3>
    <p style="font-size:13px;color:var(--text2);margin-bottom:16px">
      Entities that own each other in a loop — strong indicator of shell company structures.
    </p>
    <div id="rings-list"></div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════
     PAGE: Transactions
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="page" id="page-transactions">
  <div class="card">
    <h3>Suspicious Transactions (Structuring: $9,000–$10,000)</h3>
    <p style="font-size:13px;color:var(--text2);margin-bottom:16px">
      Transactions just below the $10,000 reporting threshold — potential structuring/smurfing.
    </p>
    <div class="scrollable-table" id="suspicious-txns"></div>
  </div>
  <div class="card">
    <h3>Entity Transaction Lookup</h3>
    <div class="flex gap-8 mb-16">
      <input type="text" id="txn-entity-id" placeholder="Entity ID" style="width:200px">
      <button onclick="loadEntityTxns()">Load Transactions</button>
    </div>
    <div class="scrollable-table" id="entity-txns"></div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════
     PAGE: Shell Companies
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="page" id="page-shells">
  <div class="card">
    <h3>Shell Company Indicators</h3>
    <p style="font-size:13px;color:var(--text2);margin-bottom:16px">
      Entities in high/medium-risk jurisdictions with no operational address.
    </p>
    <div class="scrollable-table" id="shells-table"></div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════
     PAGE: Cypher Console
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="page" id="page-cypher">
  <div class="card query-editor">
    <h3>Neo4j Cypher Console (Read-Only)</h3>
    <div class="flex gap-8 mb-16" style="flex-wrap:wrap">
      <button class="secondary" onclick="setCypher('top-risk')">Top Risk</button>
      <button class="secondary" onclick="setCypher('ubo')">UBO Query</button>
      <button class="secondary" onclick="setCypher('rings')">Circular Ownership</button>
      <button class="secondary" onclick="setCypher('shells')">Shell Companies</button>
      <button class="secondary" onclick="setCypher('structuring')">Structuring</button>
      <button class="secondary" onclick="setCypher('pep')">PEP Exposure</button>
      <button class="secondary" onclick="setCypher('schema')">Schema</button>
    </div>
    <textarea id="cypher-input" rows="8" placeholder="Enter Cypher query..."></textarea>
    <button onclick="runCypher()">▶ Execute</button>
    <div class="query-results" id="cypher-results" style="display:none"></div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════
     PAGE: SPARQL Console
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="page" id="page-sparql">
  <div class="card query-editor">
    <h3>GraphDB SPARQL Console (Read-Only)</h3>
    <div class="flex gap-8 mb-16" style="flex-wrap:wrap">
      <button class="secondary" onclick="setSparql('graphs')">Named Graphs</button>
      <button class="secondary" onclick="setSparql('classes')">FIBO Classes</button>
      <button class="secondary" onclick="setSparql('properties')">KYC Properties</button>
      <button class="secondary" onclick="setSparql('mapping')">FIBO↔GLEIF Mapping</button>
      <button class="secondary" onclick="setSparql('subclasses')">Subclass Hierarchy</button>
    </div>
    <textarea id="sparql-input" rows="8" placeholder="Enter SPARQL query..."></textarea>
    <button onclick="runSparql()">▶ Execute</button>
    <div class="query-results" id="sparql-results" style="display:none"></div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════
     PAGE: Ontology Browser
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="page" id="page-ontology">
  <div class="card-grid card-grid-2">
    <div class="card">
      <h3>Named Graphs (GraphDB)</h3>
      <div id="ontology-graphs"></div>
    </div>
    <div class="card">
      <h3>Neo4j Labels & Relationships</h3>
      <div id="ontology-schema"></div>
    </div>
  </div>
</div>

</div><!-- /content -->
</div><!-- /main -->

<script>
// ═══════════════════════════════════════════════════════════════════════════════
//  API helper
// ═══════════════════════════════════════════════════════════════════════════════
const API = '';
async function api(path, opts){
  const r = await fetch(API + path, opts);
  if(!r.ok) throw new Error(`${r.status}: ${await r.text()}`);
  return r.json();
}

// ═══════════════════════════════════════════════════════════════════════════════
//  Navigation
// ═══════════════════════════════════════════════════════════════════════════════
const navItems = document.querySelectorAll('.nav-item');
const pages = document.querySelectorAll('.page');
const pageTitle = document.getElementById('page-title');
const pageTitles = {
  dashboard:'Dashboard', entities:'Entity Explorer', persons:'Persons & Watchlists',
  ubo:'UBO Chain Traversal', graph:'Graph Explorer', risk:'Risk Analysis',
  rings:'Circular Ownership', transactions:'Transaction Analysis', shells:'Shell Companies',
  cypher:'Cypher Console', sparql:'SPARQL Console', ontology:'Ontology Browser'
};

navItems.forEach(item => item.addEventListener('click', () => {
  const pg = item.dataset.page;
  navItems.forEach(n=>n.classList.remove('active'));
  item.classList.add('active');
  pages.forEach(p=>p.classList.remove('active'));
  document.getElementById('page-'+pg).classList.add('active');
  pageTitle.textContent = pageTitles[pg]||pg;
  if(pageLoaders[pg]) pageLoaders[pg]();
}));

const pageLoaders = {
  dashboard: loadDashboard,
  entities: loadEntities,
  persons: ()=>loadPersons(),
  risk: loadRisk,
  rings: loadRings,
  transactions: loadTransactions,
  shells: loadShells,
  ontology: loadOntology,
};

// ═══════════════════════════════════════════════════════════════════════════════
//  Utilities
// ═══════════════════════════════════════════════════════════════════════════════
function riskClass(score){
  if(score>=70)return'risk-critical';if(score>=50)return'risk-high';
  if(score>=30)return'risk-medium';if(score>=10)return'risk-low';return'risk-clean';
}
function tierTag(tier){return `<span class="tag tag-${tier||'low'}">${tier||'?'}</span>`}
function personTags(row){
  let t='';
  if(row.isSanctioned)t+='<span class="tag tag-sanctioned">SANCTIONED</span> ';
  if(row.isPEP)t+='<span class="tag tag-pep">PEP</span> ';
  return t;
}
function makeTable(headers,rows,cellFn){
  let h='<table><thead><tr>'+headers.map(h=>`<th>${h}</th>`).join('')+'</tr></thead><tbody>';
  rows.forEach(r=>{h+='<tr>'+cellFn(r)+'</tr>'});
  return h+'</tbody></table>';
}
function loading(el){el.innerHTML='<div class="loading-overlay"><div class="spinner"></div>&nbsp; Loading...</div>'}
function num(n,d=0){return typeof n==='number'?n.toFixed(d):'–'}

// ═══════════════════════════════════════════════════════════════════════════════
//  Dashboard
// ═══════════════════════════════════════════════════════════════════════════════
async function loadDashboard(){
  const kpi = document.getElementById('kpi-row');
  loading(kpi);
  try{
    const d = await api('/api/kpis');
    kpi.innerHTML = [
      {v:d.entities,l:'Entities'},{v:d.persons,l:'Persons'},
      {v:d.sanctioned,l:'Sanctioned',c:'var(--red)'},{v:d.peps,l:'PEPs',c:'var(--purple)'},
      {v:d.highRisk,l:'High Risk (≥70)',c:'var(--orange)'}
    ].map(k=>`<div class="card kpi"><div class="kpi-value" style="color:${k.c||'var(--text)'}">${k.v}</div><div class="kpi-label">${k.l}</div></div>`).join('');

    // Risk distribution chart
    const dist = await api('/api/risk/distribution');
    const colors = {Critical:'#f85149',High:'#d29922',Medium:'#e3b341',Low:'#3fb950',Clean:'#30363d'};
    const maxDist = Math.max(...dist.map(d=>d.count),1);
    document.getElementById('risk-chart').innerHTML = dist.map(d=>`
      <div style="flex:1;text-align:center">
        <div class="chart-bar-value">${d.count}</div>
        <div class="chart-bar-item" style="height:${(d.count/maxDist)*100}%;background:${colors[d.bucket]||'#58a6ff'}"></div>
        <div class="chart-bar-label">${d.bucket}</div>
      </div>`).join('');

    // Jurisdiction chart
    const jurs = await api('/api/risk/jurisdictions');
    const maxJur = Math.max(...jurs.map(j=>j.avgScore),1);
    document.getElementById('jur-chart').innerHTML = jurs.map(j=>{
      const c = j.tier==='high'?'#f85149':j.tier==='medium'?'#d29922':'#3fb950';
      return `<div style="flex:1;text-align:center">
        <div class="chart-bar-value">${num(j.avgScore,0)}</div>
        <div class="chart-bar-item" style="height:${(j.avgScore/maxJur)*100}%;background:${c}"></div>
        <div class="chart-bar-label">${j.jurisdiction}</div>
      </div>`;
    }).join('');

    // Top risk table
    const top = await api('/api/entities?limit=15&sort=score');
    document.getElementById('dash-top-risk').innerHTML = makeTable(
      ['ID','Name','Jurisdiction','Tier','Score'],
      top.items,
      r=>`<td><a href="#" onclick="showEntity('${r.id}');return false">${r.id}</a></td>
          <td>${r.name}</td><td>${r.jurisdiction}</td><td>${tierTag(r.riskTier)}</td>
          <td class="${riskClass(r.score)}">${r.score}</td>`
    );
  }catch(e){kpi.innerHTML=`<div class="card" style="color:var(--red)">Error: ${e.message}</div>`}
}

// ═══════════════════════════════════════════════════════════════════════════════
//  Entity Explorer
// ═══════════════════════════════════════════════════════════════════════════════
let entityOffset=0;
const entityLimit=30;

async function loadEntities(){
  const tbl = document.getElementById('entity-table');
  loading(tbl);
  const search = document.getElementById('entity-search').value;
  const jur = document.getElementById('entity-jur-filter').value;
  const tier = document.getElementById('entity-tier-filter').value;
  let url = `/api/entities?limit=${entityLimit}&offset=${entityOffset}`;
  if(search)url+=`&search=${encodeURIComponent(search)}`;
  if(jur)url+=`&jurisdiction=${jur}`;
  if(tier)url+=`&risk_tier=${tier}`;
  const d = await api(url);
  document.getElementById('entity-page-info').textContent = `${entityOffset+1}–${Math.min(entityOffset+entityLimit,d.total)} of ${d.total}`;
  tbl.innerHTML = makeTable(
    ['ID','Name','LEI','Jurisdiction','Tier','Score','Category','Active'],
    d.items,
    r=>`<td><a href="#" onclick="showEntity('${r.id}');return false">${r.id}</a></td>
        <td>${r.name||''}</td><td style="font-size:11px">${r.lei||''}</td><td>${r.jurisdiction||''}</td>
        <td>${tierTag(r.riskTier)}</td><td class="${riskClass(r.score)}">${num(r.score,0)}</td>
        <td style="font-size:11px">${r.category||''}</td><td>${r.isActive?'✓':'✗'}</td>`
  );
}
document.getElementById('entity-search').addEventListener('input', ()=>{entityOffset=0;loadEntities()});
document.getElementById('entity-jur-filter').addEventListener('change', ()=>{entityOffset=0;loadEntities()});
document.getElementById('entity-tier-filter').addEventListener('change', ()=>{entityOffset=0;loadEntities()});
document.getElementById('entity-prev').addEventListener('click', ()=>{entityOffset=Math.max(0,entityOffset-entityLimit);loadEntities()});
document.getElementById('entity-next').addEventListener('click', ()=>{entityOffset+=entityLimit;loadEntities()});

async function showEntity(id){
  // Navigate to entities page if not there
  document.querySelector('[data-page="entities"]').click();
  const card = document.getElementById('entity-detail-card');
  const body = document.getElementById('entity-detail-body');
  card.style.display='block';
  loading(body);
  document.getElementById('entity-detail-title').textContent = id;
  const d = await api(`/api/entities/${id}`);
  const e = d.entity;
  body.innerHTML = `
    <div class="detail-panel">
      <div>
        <div class="detail-field"><label>Name</label><div class="val">${e.name}</div></div>
        <div class="detail-field"><label>LEI</label><div class="val" style="font-family:monospace">${e.lei}</div></div>
        <div class="detail-field"><label>Jurisdiction</label><div class="val">${e.jurisdiction} (${e.jurisdictionName||''}) ${tierTag(e.riskTier)}</div></div>
        <div class="detail-field"><label>Category</label><div class="val">${e.category}</div></div>
        <div class="detail-field"><label>Active</label><div class="val">${e.isActive?'Yes':'No'}</div></div>
        <div class="detail-field"><label>Operational Address</label><div class="val">${e.hasOperationalAddress?'Yes':'No'}</div></div>
      </div>
      <div>
        <div class="detail-field"><label>KYC Risk Score</label><div class="val ${riskClass(e.kycRiskScore)}" style="font-size:24px;font-weight:700">${e.kycRiskScore||0}/100</div></div>
        <div class="detail-field"><label>PageRank</label><div class="val">${num(e.pageRankScore,4)}</div></div>
        <div class="detail-field"><label>Community (Louvain)</label><div class="val">${e.louvainCommunityId||'–'}</div></div>
        <div class="detail-field"><label>SCC Component</label><div class="val">${e.sccComponentId!=null?'⚠ Ring #'+e.sccComponentId:'None'}</div></div>
      </div>
    </div>
    <div class="card-grid card-grid-3 mt-8">
      <div><h3 style="font-size:14px;margin-bottom:8px">Parents (owned by)</h3>
        ${d.parents.length?d.parents.map(p=>`<div>↑ <a href="#" onclick="showEntity('${p.id}');return false">${p.name}</a> (${num(p.pct,0)}%)</div>`).join(''):'<span style="color:var(--text2)">None</span>'}
      </div>
      <div><h3 style="font-size:14px;margin-bottom:8px">Children (subsidiaries)</h3>
        ${d.children.length?d.children.map(c=>`<div>↓ <a href="#" onclick="showEntity('${c.id}');return false">${c.name}</a></div>`).join(''):'<span style="color:var(--text2)">None</span>'}
      </div>
      <div><h3 style="font-size:14px;margin-bottom:8px">Controllers</h3>
        ${d.controllers.length?d.controllers.map(c=>`<div>👤 ${c.name} ${personTags(c)}</div>`).join(''):'<span style="color:var(--text2)">None</span>'}
      </div>
    </div>
    <div class="mt-8 flex gap-8">
      <button class="secondary" onclick="document.getElementById('ubo-entity-id').value='${id}';document.querySelector('[data-page=ubo]').click();findUBO()">🔗 Find UBO</button>
      <button class="secondary" onclick="document.getElementById('graph-entity-id').value='${id}';document.querySelector('[data-page=graph]').click();loadGraph()">🕸️ Visualize Graph</button>
      <button class="secondary" onclick="document.getElementById('txn-entity-id').value='${id}';document.querySelector('[data-page=transactions]').click();loadEntityTxns()">💰 Transactions</button>
    </div>`;
}

