// ═══════════════════════════════════════════════════════════════════════════════
//  Cypher Console
// ═══════════════════════════════════════════════════════════════════════════════
const CYPHER_PRESETS = {
  'top-risk': `MATCH (e:LegalEntity)
WHERE e.kycRiskScore > 0
RETURN e.id AS id, e.name AS name, e.jurisdiction AS jurisdiction,
       e.kycRiskScore AS score
ORDER BY score DESC LIMIT 20`,
  'ubo': `MATCH path = (e:LegalEntity {id: 'ENTITY_0042'})
      -[:DIRECTLY_OWNED_BY*0..6]->()
      -[:CONTROLLED_BY]->(p:NaturalPerson)
RETURN p.name AS ubo, p.nationality AS nationality,
       p.isPEP AS isPEP, p.isSanctioned AS isSanctioned,
       length(path) AS hops
ORDER BY hops`,
  'rings': `MATCH (e:LegalEntity)
WHERE e.sccComponentId IS NOT NULL
WITH e.sccComponentId AS scc, collect(e.name) AS members
WHERE size(members) > 1
RETURN scc, members`,
  'shells': `MATCH (e:LegalEntity)
WHERE e.riskTier IN ['medium', 'high']
  AND e.hasOperationalAddress = false
RETURN e.id, e.name, e.jurisdiction, e.kycRiskScore
ORDER BY e.kycRiskScore DESC LIMIT 20`,
  'structuring': `MATCH (a:LegalEntity)-[t:TRANSACTION]->(b:LegalEntity)
WHERE t.amount > 9000 AND t.amount < 10000
WITH a, b, count(t) AS txns
WHERE txns >= 2
RETURN a.name AS from, b.name AS to, txns
ORDER BY txns DESC LIMIT 20`,
  'pep': `MATCH (e:LegalEntity)-[:CONTROLLED_BY]->(pep:PoliticallyExposedPerson)
RETURN e.name AS entity, e.jurisdiction AS jur,
       pep.name AS pep, pep.nationality AS nationality
LIMIT 20`,
  'schema': `CALL db.labels() YIELD label RETURN label ORDER BY label`
};

function setCypher(key){document.getElementById('cypher-input').value=CYPHER_PRESETS[key]||''}

async function runCypher(){
  const q=document.getElementById('cypher-input').value.trim();
  if(!q)return;
  const el=document.getElementById('cypher-results');
  el.style.display='block';loading(el);
  try{
    const d=await api('/api/cypher',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({query:q})});
    if(!d.rows.length){el.innerHTML='<pre>(no results)</pre>';return}
    const keys=Object.keys(d.rows[0]);
    el.innerHTML=makeTable(keys,d.rows,r=>keys.map(k=>`<td>${JSON.stringify(r[k])}</td>`).join(''));
  }catch(e){el.innerHTML=`<pre style="color:var(--red)">${e.message}</pre>`}
}

// ═══════════════════════════════════════════════════════════════════════════════
//  SPARQL Console
// ═══════════════════════════════════════════════════════════════════════════════
const SPARQL_PRESETS = {
  'graphs': `SELECT ?graph (COUNT(*) AS ?triples)
WHERE { GRAPH ?graph { ?s ?p ?o } }
GROUP BY ?graph ORDER BY DESC(?triples)`,
  'classes': `PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?class ?label WHERE {
  ?class a owl:Class .
  ?class rdfs:label ?label .
  FILTER(CONTAINS(STR(?class), "edmcouncil.org"))
} ORDER BY ?label LIMIT 30`,
  'properties': `PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?prop ?type ?label WHERE {
  GRAPH <http://kg/kyc/ontology> {
    ?prop a ?type .
    FILTER(?type IN (owl:ObjectProperty, owl:DatatypeProperty))
    OPTIONAL { ?prop rdfs:label ?label }
  }
} ORDER BY ?type ?label`,
  'mapping': `PREFIX owl: <http://www.w3.org/2002/07/owl#>
SELECT ?s ?p ?o WHERE {
  GRAPH <http://kg/mapping/fibo2glei> { ?s ?p ?o }
}`,
  'subclasses': `PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX fibo-be: <https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/LegalPersons/>
SELECT ?class ?label WHERE {
  ?class rdfs:subClassOf* fibo-be:LegalPerson .
  OPTIONAL { ?class rdfs:label ?label }
} ORDER BY ?label`
};

function setSparql(key){document.getElementById('sparql-input').value=SPARQL_PRESETS[key]||''}

async function runSparql(){
  const q=document.getElementById('sparql-input').value.trim();
  if(!q)return;
  const el=document.getElementById('sparql-results');
  el.style.display='block';loading(el);
  try{
    const d=await api('/api/sparql',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({query:q})});
    if(d.type==='ask'){el.innerHTML=`<pre>Result: ${d.result}</pre>`;return}
    if(!d.rows||!d.rows.length){el.innerHTML='<pre>(no results)</pre>';return}
    const keys=Object.keys(d.rows[0]);
    el.innerHTML=makeTable(keys,d.rows,r=>keys.map(k=>`<td>${r[k]||''}</td>`).join(''));
  }catch(e){el.innerHTML=`<pre style="color:var(--red)">${e.message}</pre>`}
}

// ═══════════════════════════════════════════════════════════════════════════════
//  Ontology Browser
// ═══════════════════════════════════════════════════════════════════════════════
async function loadOntology(){
  const g = document.getElementById('ontology-graphs');
  const s = document.getElementById('ontology-schema');
  loading(g);loading(s);
  try{
    const graphs = await api('/api/graphdb/graphs');
    g.innerHTML = makeTable(['Named Graph','Triples'],graphs,
      r=>`<td style="font-size:12px">${r.graph}</td><td>${r.triples.toLocaleString()}</td>`);
    const schema = await api('/api/schema');
    s.innerHTML = `
      <h3 style="font-size:14px;margin-bottom:8px">Node Labels</h3>
      <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:16px">
        ${schema.labels.map(l=>`<span class="tag" style="background:var(--bg3)">${l}</span>`).join('')}
      </div>
      <h3 style="font-size:14px;margin-bottom:8px">Relationship Types</h3>
      <div style="display:flex;flex-wrap:wrap;gap:6px">
        ${schema.relationshipTypes.map(r=>`<span class="tag" style="background:var(--bg3)">${r}</span>`).join('')}
      </div>`;
  }catch(e){g.innerHTML=`<div style="color:var(--red)">${e.message}</div>`}
}

// ═══════════════════════════════════════════════════════════════════════════════
//  Init
// ═══════════════════════════════════════════════════════════════════════════════
loadDashboard();

// Populate jurisdiction dropdown
api('/api/risk/jurisdictions').then(jurs=>{
  const sel=document.getElementById('entity-jur-filter');
  jurs.forEach(j=>{const o=document.createElement('option');o.value=j.jurisdiction;o.textContent=j.jurisdiction;sel.appendChild(o)});
}).catch(()=>{});
</script>
</body>
</html>
