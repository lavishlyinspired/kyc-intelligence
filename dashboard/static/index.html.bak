async function loadPersons(filter){
  const tbl = document.getElementById('persons-table');
  loading(tbl);
  const url = filter ? `/api/persons?filter_type=${filter}` : '/api/persons';
  const d = await api(url);
  tbl.innerHTML = makeTable(
    ['ID','Name','Nationality','Flags','Controlled Entities'],
    d,
    r=>`<td>${r.id}</td><td>${r.name}</td><td>${r.nationality}</td>
        <td>${personTags(r)}</td>
        <td style="font-size:11px">${(r.controlledEntities||[]).join(', ')||'–'}</td>`
  );
}

// ═══════════════════════════════════════════════════════════════════════════════
//  UBO Chains
// ═══════════════════════════════════════════════════════════════════════════════
async function findUBO(){
  const id = document.getElementById('ubo-entity-id').value.trim();
  if(!id)return;
  const depth = document.getElementById('ubo-depth').value;
  const el = document.getElementById('ubo-results');
  loading(el);
  const d = await api(`/api/ubo/${id}?max_depth=${depth}`);
  if(!d.ubos.length){el.innerHTML='<div style="color:var(--text2)">No UBO found for '+id+'</div>';return}
  el.innerHTML = d.ubos.map(u=>`
    <div class="card">
      <div class="flex flex-between flex-center">
        <div>
          <strong>${u.name}</strong> (${u.nationality}) ${personTags(u)}
          <div style="font-size:12px;color:var(--text2)">${u.hops} hop(s)</div>
        </div>
      </div>
      <div style="margin-top:8px;font-size:12px;color:var(--text2)">
        Chain: ${u.chain.map(c=>c.name||c.id).join(' → ')}
      </div>
    </div>
  `).join('');
}

// ═══════════════════════════════════════════════════════════════════════════════
//  Graph Explorer (canvas-based force graph)
// ═══════════════════════════════════════════════════════════════════════════════
let graphData = null;
let graphAnim = null;

async function loadGraph(){
  const id = document.getElementById('graph-entity-id').value.trim();
  if(!id)return;
  const depth = document.getElementById('graph-depth').value;
  graphData = await api(`/api/graph/${id}?depth=${depth}`);
  renderGraph();
}

function renderGraph(){
  const canvas = document.getElementById('graph-canvas');
  const ctx = canvas.getContext('2d');
  const dpr = window.devicePixelRatio||1;
  canvas.width = canvas.offsetWidth*dpr;
  canvas.height = canvas.offsetHeight*dpr;
  ctx.scale(dpr,dpr);
  const W = canvas.offsetWidth, H = canvas.offsetHeight;

  if(!graphData||!graphData.nodes.length){
    ctx.fillStyle='#8b949e';ctx.font='14px sans-serif';
    ctx.fillText('No data — enter an entity ID and click Visualize',W/2-180,H/2);return;
  }

  const nodes = graphData.nodes.map((n,i)=>({
    ...n, x:W/2+Math.cos(i*2.4)*150+Math.random()*100,
    y:H/2+Math.sin(i*2.4)*150+Math.random()*100, vx:0, vy:0
  }));
  const nodeMap = {};
  nodes.forEach(n=>nodeMap[n.id]=n);
  const edges = graphData.edges.filter(e=>nodeMap[e.source]&&nodeMap[e.target]);

  function nodeColor(n){
    if(n.isSanctioned)return'#f85149';
    if(n.isPEP)return'#bc8cff';
    if(n.labels&&n.labels.includes('NaturalPerson'))return'#8b949e';
    if(n.score>=50)return'#f0883e';
    return'#58a6ff';
  }

  if(graphAnim)cancelAnimationFrame(graphAnim);
  let iter=0;
  function tick(){
    // Simple force simulation
    nodes.forEach(a=>{
      nodes.forEach(b=>{
        if(a===b)return;
        let dx=b.x-a.x,dy=b.y-a.y,d=Math.sqrt(dx*dx+dy*dy)||1;
        if(d<150){const f=(150-d)*0.02;a.vx-=dx/d*f;a.vy-=dy/d*f;}
      });
      a.vx+=(W/2-a.x)*0.001;a.vy+=(H/2-a.y)*0.001;
    });
    edges.forEach(e=>{
      const a=nodeMap[e.source],b=nodeMap[e.target];
      if(!a||!b)return;
      let dx=b.x-a.x,dy=b.y-a.y,d=Math.sqrt(dx*dx+dy*dy)||1;
      const f=(d-100)*0.005;
      a.vx+=dx/d*f;a.vy+=dy/d*f;
      b.vx-=dx/d*f;b.vy-=dy/d*f;
    });
    nodes.forEach(n=>{
      n.vx*=0.9;n.vy*=0.9;
      n.x+=n.vx;n.y+=n.vy;
      n.x=Math.max(30,Math.min(W-30,n.x));
      n.y=Math.max(30,Math.min(H-30,n.y));
    });

    // Draw
    ctx.clearRect(0,0,W,H);
    // Edges
    edges.forEach(e=>{
      const a=nodeMap[e.source],b=nodeMap[e.target];if(!a||!b)return;
      ctx.beginPath();ctx.moveTo(a.x,a.y);ctx.lineTo(b.x,b.y);
      ctx.strokeStyle=e.type==='CONTROLLED_BY'?'#bc8cff44':'#58a6ff44';
      ctx.lineWidth=1;ctx.stroke();
    });
    // Nodes
    nodes.forEach(n=>{
      const r=n.labels&&n.labels.includes('NaturalPerson')?6:10;
      ctx.beginPath();ctx.arc(n.x,n.y,r,0,Math.PI*2);
      ctx.fillStyle=nodeColor(n);ctx.fill();
      ctx.strokeStyle='#0f1117';ctx.lineWidth=2;ctx.stroke();
      ctx.fillStyle='#e6edf3';ctx.font='10px sans-serif';ctx.textAlign='center';
      ctx.fillText((n.name||n.id).slice(0,20),n.x,n.y+r+12);
    });

    iter++;
    if(iter<200)graphAnim=requestAnimationFrame(tick);
  }
  tick();
}

// ═══════════════════════════════════════════════════════════════════════════════
//  Risk Analysis
// ═══════════════════════════════════════════════════════════════════════════════
async function loadRisk(){
  const dist = await api('/api/risk/distribution');
  const colors = {Critical:'#f85149',High:'#d29922',Medium:'#e3b341',Low:'#3fb950',Clean:'#30363d'};
  const maxD = Math.max(...dist.map(d=>d.count),1);
  document.getElementById('risk-dist-chart').innerHTML = dist.map(d=>`
    <div style="flex:1;text-align:center">
      <div class="chart-bar-value">${d.count}</div>
      <div class="chart-bar-item" style="height:${(d.count/maxD)*100}%;background:${colors[d.bucket]||'#58a6ff'}"></div>
      <div class="chart-bar-label">${d.bucket}</div>
    </div>`).join('');

  const jurs = await api('/api/risk/jurisdictions');
  document.getElementById('jur-heatmap').innerHTML = makeTable(
    ['Jurisdiction','Tier','Count','Avg Score','Max Score'],
    jurs,
    r=>`<td>${r.jurisdiction}</td><td>${tierTag(r.tier)}</td><td>${r.count}</td>
        <td class="${riskClass(r.avgScore)}">${num(r.avgScore,1)}</td>
        <td class="${riskClass(r.maxScore)}">${num(r.maxScore,0)}</td>`
  );
}

