# ─── GraphDB ──────────────────────────────────────────────────────────────────
GRAPHDB_URL=http://localhost:7200
GRAPHDB_REPO=kyc-kg

# ─── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=
NEO4J_PASSWORD=

# ─── LLM (optional — only required for the GraphRAG agent, script 09) ─────────
# Set ONE of the four options below. Priority: Anthropic → OpenAI → DeepSeek → Ollama.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# DeepSeek cloud (free tier at https://platform.deepseek.com)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Ollama local — no API key needed.
# Pull first:  ollama pull deepseek-v3.2:cloud
# Then set:    OLLAMA_MODEL=deepseek-v3.2:cloud
OLLAMA_MODEL=
OLLAMA_BASE_URL=http://localhost:11434/v1
