# ─── GraphDB ──────────────────────────────────────────────────────────────────
GRAPHDB_URL=http://localhost:7200
GRAPHDB_REPO=kyc-kg

# ─── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
