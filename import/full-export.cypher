UNWIND [{uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/OwnershipParties/InvestorContract", properties:{n4sch__label:["investor contract"], n4sch__definition:["Contract setting out the terms under which some investor invests in the entity and setting out the rights which are conferred on that investor."], n4sch__name:"InvestorContract"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/CorporateControl/DomesticUltimateParent", properties:{n4sch__label:["domestic ultimate parent"], n4sch__definition:["party that is recognized as the ultimate parent of a given organization within the country or jurisdiction of incorporation or organization"], n4sch__name:"DomesticUltimateParent"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/CorporateControl/TotalControllingInterestParty", properties:{n4sch__label:["total controlling interest party"], n4sch__definition:["voting shareholder that owns 100 percent of the voting shares in some legal entity"], n4sch__name:"TotalControllingInterestParty"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/CorporateControl/SignificantShareholder", properties:{n4sch__label:["significant shareholder"], n4sch__definition:["party that owns a significant voting stake in an organization that is less than 50 percent but greater than some threshold"], n4sch__name:"SignificantShareholder"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/ControlParties/MajorityControllingParty", properties:{n4sch__label:["majority controlling party"], n4sch__definition:["controlling party that possesses, either directly or indirectly, the power to direct or cause the direction of the management and policies of a legal person, whether through the ownership of a majority of voting securities, by contract, or otherwise"], n4sch__name:"MajorityControllingParty"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/ControlParties/DeJureControllingInterestParty", properties:{n4sch__label:["de jure controlling interest party"], n4sch__definition:["party that has the legal authority to exercise control"], n4sch__name:"DeJureControllingInterestParty"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/ControlParties/EntityControllingParty", properties:{n4sch__label:["entity controlling party"], n4sch__definition:["party that has the authority to control some legal entity"], n4sch__name:"EntityControllingParty"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/FormalBusinessOrganizations/JointVenture", properties:{n4sch__name:"JointVenture"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/CorporateControl/Subsidiary", properties:{n4sch__label:["subsidiary"], n4sch__definition:["legal entity that is entirely or majority owned and controlled by another legal entity"], n4sch__name:"Subsidiary"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/ControlParties/TotalOwner", properties:{n4sch__label:["total owner"], n4sch__definition:["party that has 100 percent ownership some legal entity"], n4sch__name:"TotalOwner"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/ControlParties/ControlledParty", properties:{n4sch__label:["controlled party"], n4sch__definition:["person or organization over which some party exercises some form of authority or influence with respect to some situation"], n4sch__name:"ControlledParty"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/CorporateControl/GlobalUltimateParent", properties:{n4sch__label:["global ultimate parent"], n4sch__definition:["party that is recognized as the ultimate parent of a given organization world-wide"], n4sch__name:"GlobalUltimateParent"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/CorporateControl/JointVenturePartner", properties:{n4sch__label:["joint venture partner"], n4sch__definition: