UNWIND [{uri:"https://spec.edmcouncil.org/fibo/ontology/FND/OwnershipAndControl/Ownership/Asset", properties:{n4sch__name:"Asset"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/CorporateOwnership/Shareholder", properties:{n4sch__label:["shareholder"], n4sch__definition:["party that owns shares in and has rights and responsibilities with respect to some asset, provided in exchange for investment"], n4sch__name:"Shareholder"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/CorporateOwnership/PurchaseLot", properties:{n4sch__label:["purchase lot"], n4sch__definition:["financial asset that is a block of securities or other financial assets bought in one transaction on a given date at a specific price"], n4sch__name:"PurchaseLot"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/CorporateOwnership/Shareholding", properties:{n4sch__label:["shareholding"], n4sch__definition:["ownership interest in the equity of a company, represented by shares that confer financial rights and governance privileges"], n4sch__name:"Shareholding"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/CorporateOwnership/TaxLot", properties:{n4sch__label:["tax lot"], n4sch__definition:["financial asset that is a block of securities or other financial assets with a distinct cost basis for tax reporting purposes"], n4sch__name:"TaxLot"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/OwnershipParties/ConstitutionalOwner", properties:{n4sch__label:["constitutional owner"], n4sch__definition:["entity owner that holds an equity stake in said entity, in the form of shareholders' equity"], n4sch__name:"ConstitutionalOwner"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/OwnershipParties/ForeignBranchOwnership", properties:{n4sch__label:["foreign branch ownership"], n4sch__definition:["ownership by some party of some formal organization or organizational sub-