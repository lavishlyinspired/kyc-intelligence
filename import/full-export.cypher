4sch__name:"LegallyCompetentNaturalPerson"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/LegalPersons/ReligiousObjective", properties:{n4sch__label:["religious objective"], n4sch__definition:["not-for-profit objective that reflects the religious goals of an organization"], n4sch__name:"ReligiousObjective"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/LegalPersons/VariableInterestEntity", properties:{n4sch__label:["variable interest entity"], n4sch__definition:["legal entity whose shareholders are entitled to a percentage of a named company's profits via a private contract"], n4sch__name:"VariableInterestEntity"}}, {uri:"https://www.omg.org/spec/Commons/Organizations/LegalEntity", properties:{n4sch__name:"LegalEntity"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/CorporateOwnership/BeneficialOwnership", properties:{n4sch__label:["beneficial ownership"], n4sch__definition:["situation linking party that enjoys the benefits of ownership (such as receipt of income) of something even though its ownership (title) may be in the name of another party (called a nominee or registered owner) to the asset that they own"], n4sch__name:"BeneficialOwnership"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/CorporateOwnership/BeneficialOwner", properties:{n4sch__label:["beneficial owner"], n4sch__definition:["party that enjoys the benefits of ownership (such as receipt of income) of something even though its ownership (title) may be in the name of another party (called a nominee or registered owner)"], n4sch__name:"BeneficialOwner"}}] AS row
