ontrol", properties:{n4sch__label:["influence-based de facto control"], n4sch__definition:["informal control that involves influence over some party"], n4sch__name:"InfluenceBasedDeFactoControl"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/ControlParties/InfluenceBasedDeFactoControllingParty", properties:{n4sch__label:["influence-based de facto controlling party"], n4sch__definition:["party that holds influence-based control over some other party"], n4sch__name:"InfluenceBasedDeFactoControllingParty"}}] AS row
