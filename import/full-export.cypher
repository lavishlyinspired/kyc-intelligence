UNWIND [{uri:"https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/LegalPersons/CharteredLegalPerson", properties:{n4sch__label:["chartered legal person"], n4sch__definition:["a legal person created by a royal charter or decree"], n4sch__name:"CharteredLegalPerson"}}, {uri:"https://www.omg.org/spec/Commons/Organizations/LegalPerson", properties:{n4sch__name:"LegalPerson"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/FND/GoalsAndObjectives/Objectives/BusinessObjective", properties:{n4sch__name:"BusinessObjective"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/LegalPersons/SpecialPurposeVehicle", properties:{n4sch__label:["fonds commun de placement", "special purpose vehicle"], n4sch__definition:["legal entity created to fulfill narrow, specific, and frequently temporary objectives"], n4sch__name:"SpecialPurposeVehicle"}}, {uri:"https://www.omg.org/spec/Commons/DatesAndTimes/Date", properties:{n4sch__name:"Date"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/FND/Law/LegalCapacity/License", properties:{n4sch__name:"License"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/LegalPersons/NotForProfitObjective", properties:{n4sch__label:["not for profit objective"], n4sch__definition:["objective that reflects the charitable, educational, religious, humanitarian, public services, or other not for profit goals of an organization"], n4sch__name:"NotForProfitObjective"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/LegalPersons/BusinessLicense", properties:{n4sch__label:["business license"], n4sch__definition:["license that allows the holder to conduct business or carry out a specific profession within some jurisdiction for some period of time"], n4sch__name:"BusinessLicense"}}, {uri:"https://www.omg.org/spec/Commons/RegulatoryAgencies/Jurisdiction", properties:{n4sch__name:"Jurisdiction"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/LegalPersons/StatutoryBody", properties:{n4sch_