wnership", properties:{n4sch__label:["entity ownership"], n4sch__definition:["ownership by some party of an interest in some non-governmental formal organization"], n4sch__name:"EntityOwnership"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/LEIEntities/RelationshipQualifier", properties:{n4sch__name:"RelationshipQualifier"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/LEIEntities/RelationshipStatus", properties:{n4sch__name:"RelationshipStatus"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/OwnershipParties/DirectConsolidation", properties:{n4sch__label:["direct consolidation"], n4sch__definition:["direct ownership of an entity recorded as accounting consolidation"], n4sch__name:"DirectConsolidation"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/OwnershipParties/Investor", properties:{n4sch__label:["investor"], n4sch__definition:["party that owns some stake in some organization by way of investment"], n4sch__name:"Investor"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/FND/Accounting/AccountingEquity/ShareholdersEquity", properties:{n4sch__name:"ShareholdersEquity"}}] AS row
