UNWIND [{uri:"https://www.omg.org/spec/Commons/RegulatoryAgencies/isRecognizedIn", properties:{n4sch__name:"isRecognizedIn"}}, {uri:"https://www.omg.org/spec/Commons/RegulatoryAgencies/isOrganizedIn", properties:{n4sch__name:"isOrganizedIn"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/FND/Law/LegalCapacity/isConferredOn", properties:{n4sch__name:"isConferredOn"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/LegalPersons/hasIntendedLiquidationDate", properties:{n4sch__label:["has intended liquidation date"], n4sch__definition:["links an agreement, contract, or legal entity to a date on which it is scheduled to be sold"], n4sch__name:"hasIntendedLiquidationDate"}}, {uri:"https://www.omg.org/spec/Commons/ContextualDesignators/appliesTo", properties:{n4sch__name:"appliesTo"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/FND/Agreements/Contracts/hasEffectiveDate", properties:{n4sch__name:"hasEffectiveDate"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/FND/Relations/Relations/holds", properties:{n4sch__name:"holds"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/FND/GoalsAndObjectives/Objectives/hasObjective", properties:{n4sch__name:"hasObjective"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/FND/OwnershipAndControl/Ownership/hasOwningParty", properties:{n4sch__name:"hasOwningParty"}}, {uri:"https://www.omg.org/spec/Commons/RolesAndCompositions/isPlayedBy", properties:{n4sch__name:"isPlayedBy"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/CorporateOwnership/hasBeneficialOwner", properties:{n4sch__label:["has beneficial owner"], n4sch__definition:["indicates the party that retains rights in the asset they own in a beneficial ownership situation"], n4sch__name:"hasBeneficialOwner"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/CorporateOwnership/isBeneficialOwnerOf", properties:{n4sch__label:["is beneficial owner of"], n4sch__definition:["indicates an asset in which the beneficial owner holds rights (typically voting rights, management rights, etc.) in a beneficial ownership situation"], n4sch__name:"isBeneficialOwnerOf"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/FND/OwnershipAndControl/Ownership/hasOwnedAsset", properties:{n4sch__name:"hasOwnedAsset"}}, {uri:"https://www.omg.org/spec/Commons/RegistrationAuthorities/isRegisteredBy", properties:{n4sch__name:"isRegisteredBy"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/OwnershipParties/hasOwnedEntity", properties:{n4sch__label:["has owned entity"], n4sch__definition:["indicates a formal organization, including potentially a sole proprietorship, that is owned by a legal person"], n4sch__name:"hasOwnedEntity"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/OwnershipParties/hasOwningEntity", properties:{n4sch__label:["has owning entity"], n4sch__definition:["indicates a party that owns a formal organization"], n4sch__name:"hasOwningEntity"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/FND/Relations/Relations/isHeldBy", properties:{n4sch__name:"isHeldBy"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/OwnershipParties/guarantees", properties:{n4sch__label:["guarantees"], n4sch__definition:["provides a formal assurance or promise, esp. that certain conditions shall be fulfilled relating to a product, service, or transaction"], n4sch__name:"guarantees"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/OwnershipParties/hasInvestmentOwnership", properties:{n4sch__label:["has investment ownership"], n4sch__definition:["relates a legal person to the context in which it owns a formal organization"], n4sch__name:"hasInvestmentOwnership"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/OwnershipParties/hasDirectOwnership", properties:{n4sch__label:["has direct ownership"], n4sch__definition:["relates a formal organization to the situation in which it is owned directly by another entity"], n4sch__name:"hasDirectOwnership"}}] AS row
CREATE (n:Resource{uri: row.uri}) SET n += row.properties SET n:n4sch__Relationship;
UNWIND [{uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/OwnershipParties/hasInvestmentEntity", properties:{n4sch__label:["has investment entity"], n4sch__definition:["relates a legal person to a directly owned formal organization or subsidiary, depending on the percent ownership interest"], n4sch__name:"hasInvestmentEntity"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/FND/Relations/Relations/isConferredBy", properties:{n4sch__name:"isConferredBy"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/FND/Agreements/Contracts/definesTermsFor", properties:{n4sch__name:"definesTermsFor"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/OwnershipParties/hasDirectOwningEntity", properties:{n4sch__label:["has direct owning entity"], n4sch__definition:["relates a formal organization to a direct legal person / owner"], n4sch__name:"hasDirectOwningEntity"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/FND/Relations/Relations/confers", properties:{n4sch__name:"confers"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/FND/Agreements/Contracts/isQualifiedBy", properties:{n4sch__name:"isQualifiedBy"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/LEIEntities/hasOwnershipPercentage", properties:{n4sch__name:"hasOwnershipPercentage"}}, {uri:"https://www.omg.org/spec/Commons/Documents/records", properties:{n4sch__name:"records"}}, {uri:"https://www.omg.org/spec/Commons/Classifiers/isClassifiedBy", properties:{n4sch__name:"isClassifiedBy"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/FND/OwnershipAndControl/Control/isControllingPartyOf", properties:{n4sch__name:"isControllingPartyOf"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/CorporateControl/isParentCompanyOf", properties:{n4sch__label:["is parent company of"], n4sch__definition:["indicates a controlled affiliate that it owns at least 50 percent of"], n4sch__name:"isParentCompanyOf"}}, {uri:"https://www.omg.org/spec/Commons/PartiesAndSituations/hasActor", properties:{n4sch__name:"hasActor"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/CorporateControl/hasSubsidiary", properties:{n4sch__label:["has subsidiary"], n4sch__definition:["relates a legal entity to another organization that it owns at least 50 percent of"], n4sch__name:"hasSubsidiary"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/CorporateControl/isAffiliateOf", properties:{n4sch__label:["is affiliate of"], n4sch__definition:["relates a party which directly, or indirectly through one or more intermediaries, controls, or is controlled by, or is under common control by another party to that party"], n4sch__name:"isAffiliateOf", n4sch__propCharacteristics:["Symmetric"]}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/CorporateControl/hasAffiliate", properties:{n4sch__label:["has affiliate"], n4sch__definition:["has a party which directly, or indirectly through one or more intermediaries, controls, or is controlled by, or is under common control with the company"], n4sch__name:"hasAffiliate"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/CorporateControl/hasGlobalUltimateParent", properties:{n4sch__label:["has global ultimate parent"], n4sch__definition:["relates an organization to another recognized as its ultimate parent, if it has one"], n4sch__name:"hasGlobalUltimateParent"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/CorporateControl/isWhollyOwnedBy", properties:{n4sch__label:["is wholly owned by"], n4sch__definition:["relates a legal entity to a party that has 100 percent ownership and control over it"], n4sch__name:"isWhollyOwnedBy"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/CorporateControl/hasControllingAffiliate", properties:{n4sch__label:["has controlling affiliate"], n4sch__definition:["is directly, or indirectly through one or more intermediaries, controlled by"], n4sch__name:"hasControllingAffiliate"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/CorporateControl/isControllingAffiliateOf", properties:{n4sch__label:["is controlling affiliate of"], n4sch__definition:["controls directly, or indirectly through one or more intermediaries"], n4sch__name:"isControllingAffiliateOf"}}, {uri:"https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/CorporateControl/isSubsidiaryOf", properties:{n4sch__label:["is subsidiary of"], n4sch__definition:["is controlled directly, or indirectly through one or more intermediaries and owned at least 50 percent by"], n4sch__name:"isSubsidiaryOf"}}] AS row
